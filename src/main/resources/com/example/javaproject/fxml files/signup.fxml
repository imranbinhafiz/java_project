<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane
    styleClass="root"
    stylesheets="@../css/signup.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.javaproject.SignupController">

    <!-- ═══════════════════════════════════════════════════
         TOP  —  Signup GIF
         ═══════════════════════════════════════════════════ -->
    <top>
        <StackPane prefHeight="180" BorderPane.alignment="CENTER">
            <ImageView
                fitHeight="155" fitWidth="200"
                preserveRatio="true"
                StackPane.alignment="CENTER">
                <image><Image url="@../images/signup.gif"/></image>
            </ImageView>
        </StackPane>
    </top>

    <!-- ═══════════════════════════════════════════════════
         CENTRE  —  Signup Card
         ═══════════════════════════════════════════════════ -->
    <center>
        <StackPane>
            <StackPane.margin><Insets bottom="36"/></StackPane.margin>

            <!-- The card — fx:id required for entrance/exit animations -->
            <VBox fx:id="signupCard"
                  styleClass="signup-card"
                  alignment="CENTER_LEFT"
                  spacing="0"
                  maxWidth="370">

                <!-- ╌╌ Title block ╌╌ -->
                <VBox alignment="CENTER" spacing="8">
                    <VBox.margin><Insets bottom="32"/></VBox.margin>
                    <Label styleClass="signup-title"    text="Create Account"          />
                    <Label styleClass="signup-subtitle" text="Join us — it's completely free" />
                </VBox>

                <!-- ╌╌ Username ╌╌ -->
                <Label styleClass="field-label" text="Username">
                    <VBox.margin><Insets bottom="6"/></VBox.margin>
                </Label>
                <TextField
                    fx:id="usernameField"
                    styleClass="text-field"
                    promptText="Choose a username">
                    <VBox.margin><Insets bottom="22"/></VBox.margin>
                </TextField>

                <!-- ╌╌ Password ╌╌ -->
                <Label styleClass="field-label" text="Password">
                    <VBox.margin><Insets bottom="6"/></VBox.margin>
                </Label>
                <PasswordField
                    fx:id="passwordField"
                    styleClass="password-field"
                    promptText="Create a strong password">
                    <VBox.margin><Insets bottom="30"/></VBox.margin>
                </PasswordField>

                <!-- ╌╌ Sign Up button ╌╌ -->
                <Button
                    mnemonicParsing="false"
                    onAction="#handleSignupButtonClick"
                    styleClass="signup-button"
                    text="Create Account"
                    maxWidth="Infinity" />

                <!-- ╌╌ Login row ╌╌ -->
                <HBox alignment="CENTER" spacing="10" styleClass="login-row">
                    <VBox.margin><Insets top="20"/></VBox.margin>
                    <Label styleClass="login-hint" text="Already have an account?" />
                    <Button
                        fx:id="loginButton"
                        onAction="#handleLoginButtonClick"
                        styleClass="login-button"
                        text="Login" />
                </HBox>

                <!-- ╌╌ Accent bottom bar ╌╌ -->
                <Region styleClass="accent-bar" maxWidth="Infinity">
                    <VBox.margin><Insets top="30"/></VBox.margin>
                </Region>

            </VBox>
        </StackPane>
    </center>

</BorderPane>
