<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<!--
  exam_module.fxml – Exam Module Home Screen
  [CHANGED] Added "My Published Exams" card/button for publisher dashboard navigation.
  [CHANGED] Replaced emoji icons with ikonly FontIcon icons.
-->

<BorderPane style="-fx-background-color: transparent;" stylesheets="@../css/dashboard.css,@../css/exam.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javaproject.ExamModuleController">

    <top>
        <VBox spacing="4" style="-fx-padding: 28 32 0 32;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <FontIcon iconColor="white" iconLiteral="fas-graduation-cap" iconSize="24" styleClass="exam-home-icon" />
                <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #f8fafc;" text="Exam Center" />
            </HBox>
            <Label style="-fx-font-size: 14px; -fx-text-fill: #94a3b8;" text="Publish, participate, or review your exams." />
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 24 32 32 32;">

                <!-- Row 1: Publish + Participate -->
                <HBox spacing="20">

                    <!-- Publish Exam Card -->
                    <VBox alignment="CENTER" spacing="14" style="-fx-padding: 36;" styleClass="exam-home-card" HBox.hgrow="ALWAYS">
                        <FontIcon iconColor="white" iconLiteral="fas-upload" iconSize="40" styleClass="exam-home-icon" />
                        <Label styleClass="exam-home-card-title" text="Publish Exam" />
                        <Label style="-fx-text-alignment: center;" styleClass="exam-home-card-desc" text="Create a new exam with questions, set timing, and assign participants." wrapText="true" />
                        <Button maxWidth="Infinity" onAction="#handlePublishExam" styleClass="exam-home-btn-publish" text="Publish New Exam" />
                    </VBox>

                    <!-- Participate Card -->
                    <VBox alignment="CENTER" spacing="14" style="-fx-padding: 36;" styleClass="exam-home-card" HBox.hgrow="ALWAYS">
                        <FontIcon iconColor="white" iconLiteral="fas-pencil-alt" iconSize="40" styleClass="exam-home-icon" />
                        <Label styleClass="exam-home-card-title" text="Take Exam" />
                        <Label style="-fx-text-alignment: center;" styleClass="exam-home-card-desc" text="View available exams assigned to you, and review your past results." wrapText="true" />
                        <Button maxWidth="Infinity" onAction="#handleParticipateExam" styleClass="exam-home-btn-publish" text="Browse &amp; Take Exams" />
                    </VBox>

                </HBox>

                <!-- [ADDED] Row 2: My Published Exams Card -->
                <VBox alignment="CENTER" spacing="14" style="-fx-padding: 28;" styleClass="exam-home-card">
                    <FontIcon iconColor="white" iconLiteral="fas-chart-bar" iconSize="40" styleClass="exam-home-icon" />
                    <Label styleClass="exam-home-card-title" text="My Published Exams" />
                    <Label style="-fx-text-alignment: center; -fx-max-width: 500px;" styleClass="exam-home-card-desc" text="View your published exams, check participant scores, and review questions with correct answers." wrapText="true" />
                    <Button maxWidth="240" onAction="#handleMyPublishedExams" styleClass="exam-home-btn-publish">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8">
                                <Label text="Manage My Exams" textFill="#f7f2f2" />
                            </HBox>
                        </graphic>
                    </Button>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
