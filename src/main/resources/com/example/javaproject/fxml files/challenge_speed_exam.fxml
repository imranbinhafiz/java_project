<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<!-- Speed Mode Exam Scene -->
<StackPane style="-fx-background-color: transparent;"
           stylesheets="@../css/dashboard.css,@../css/challenge.css"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.javaproject.ChallengeSpeedExamController">

    <BorderPane style="-fx-background-color: transparent;">
        <top>
            <HBox styleClass="ch-topbar" alignment="CENTER_LEFT" spacing="14">
                <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>
                <FontIcon iconLiteral="fas-bolt" iconSize="18" iconColor="#fcd34d"/>
                <VBox spacing="2">
                    <Label fx:id="examTitleLabel" text="Speed Exam" styleClass="ch-title"/>
                    <Label fx:id="participantsStatusLabel" text=""
                           style="-fx-font-size:12px; -fx-text-fill:#64748b;"/>
                </VBox>
                <Pane HBox.hgrow="ALWAYS"/>
                <VBox alignment="CENTER">
                    <Label text="TIME" styleClass="ch-sec-lbl"/>
                    <Label fx:id="timerLabel" text="10:00"
                           style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#86efac;"/>
                </VBox>
            </HBox>
        </top>

        <center>
            <VBox spacing="18" style="-fx-padding: 24 36 36 36;" alignment="TOP_CENTER">

                <Label fx:id="progressLabel" text="Question 1 / 10"
                       style="-fx-font-size:13px; -fx-text-fill:#64748b; -fx-font-weight:600;"/>

                <!-- Question card -->
                <VBox fx:id="questionBox" styleClass="ch-panel" spacing="16" style="-fx-padding: 24 28 24 28;">
                    <Label fx:id="questionText" text=""
                           style="-fx-font-size:18px; -fx-text-fill:#f8fafc; -fx-font-weight:600;"
                           wrapText="true"/>
                    <Label fx:id="feedbackLabel" text=""
                           style="-fx-font-size:14px; -fx-text-fill:#86efac;"/>
                </VBox>

                <!-- Options -->
                <VBox fx:id="optionsBox" spacing="10" maxWidth="600"/>

            </VBox>
        </center>
    </BorderPane>

    <StackPane fx:id="popupOverlay" styleClass="ch-overlay" visible="false">
        <VBox fx:id="popupContent" maxWidth="380" styleClass="ch-popup" StackPane.alignment="CENTER"/>
    </StackPane>
</StackPane>
