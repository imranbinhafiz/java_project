<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<!-- Exam Phase for Swap Duel -->
<StackPane style="-fx-background-color: transparent;"
           stylesheets="@../css/dashboard.css,@../css/challenge.css"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.javaproject.ChallengeSwapExamController">

    <BorderPane style="-fx-background-color: transparent;">
        <top>
            <HBox styleClass="ch-topbar" alignment="CENTER_LEFT" spacing="14">
                <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>
                <Label fx:id="roundLabel" text="Round 1 / 3  —  Exam Phase" styleClass="ch-title"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="opponentStatusLabel" text="⏳ Opponent answering..."
                       style="-fx-font-size:13px; -fx-text-fill:#64748b;"/>
                <!-- Timer -->
                <VBox alignment="CENTER">
                    <Label text="TIME LEFT" styleClass="ch-sec-lbl"/>
                    <Label fx:id="timerLabel" text="02:00"
                           style="-fx-font-weight:bold; -fx-font-size:20px; -fx-text-fill:#86efac;"/>
                </VBox>
            </HBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true" style="-fx-background-color:transparent; -fx-border-color:transparent;">
                <VBox spacing="18" style="-fx-padding: 22 32 36 32;">

                    <!-- Question from opponent -->
                    <VBox styleClass="ch-panel" spacing="12" style="-fx-padding: 18 20 18 20;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <FontIcon iconLiteral="fas-question-circle" iconSize="16" iconColor="#818cf8"/>
                            <Label text="Your Opponent's Question" styleClass="ch-panel-title"/>
                        </HBox>
                        <Pane styleClass="ch-divider"/>
                        <Label fx:id="questionText" text=""
                               style="-fx-font-size:16px; -fx-text-fill:#e2e8f0; -fx-font-weight:600;"
                               wrapText="true"/>
                        <VBox fx:id="questionImageBox" visible="false" managed="false">
                            <ImageView fx:id="questionImageView" fitWidth="320" fitHeight="200" preserveRatio="true"/>
                        </VBox>
                    </VBox>

                    <!-- Answer panel -->
                    <VBox styleClass="ch-panel" spacing="12" style="-fx-padding: 18 20 18 20;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <FontIcon iconLiteral="fas-pen" iconSize="16" iconColor="#22c55e"/>
                            <Label text="Your Answer" styleClass="ch-panel-title" style="-fx-text-fill:#86efac;"/>
                        </HBox>
                        <Pane styleClass="ch-divider"/>

                        <TextArea fx:id="answerTextArea" styleClass="ch-field"
                                  promptText="Write your detailed answer here..."
                                  wrapText="true"
                                  style="-fx-min-height:150; -fx-pref-height:180;"/>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="uploadAnswerImageBtn" text="📎  Attach Image"
                                    styleClass="ch-btn-action" onAction="#handleUploadAnswerImage"
                                    style="-fx-font-size:12px; -fx-padding:7 14 7 14;"/>
                        </HBox>

                        <VBox fx:id="answerImageBox" visible="false" managed="false" spacing="6"
                              style="-fx-background-color:rgba(15,23,42,0.5); -fx-background-radius:10;
                                     -fx-padding:10; -fx-border-color:rgba(34,197,94,0.2); -fx-border-radius:10;">
                            <ImageView fx:id="answerImageView" fitWidth="200" fitHeight="130" preserveRatio="true"/>
                            <Button fx:id="removeAnswerImageBtn" text="✕ Remove Image"
                                    styleClass="ch-btn-red" onAction="#handleRemoveAnswerImage"
                                    style="-fx-font-size:11px; -fx-padding:4 10 4 10;"/>
                        </VBox>

                        <Button fx:id="submitAnswerBtn" text="Submit Answer  ✓"
                                styleClass="ch-btn-green" onAction="#handleSubmitAnswer"
                                maxWidth="Infinity"
                                style="-fx-font-size:14px; -fx-padding:12 0 12 0;"/>
                    </VBox>

                </VBox>
            </ScrollPane>
        </center>
    </BorderPane>

    <StackPane fx:id="popupOverlay" styleClass="ch-overlay" visible="false">
        <VBox fx:id="popupContent" maxWidth="380" styleClass="ch-popup" StackPane.alignment="CENTER"/>
    </StackPane>
</StackPane>
