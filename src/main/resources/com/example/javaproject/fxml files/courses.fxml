<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="contentArea" spacing="25.0" styleClass="content-area"
      stylesheets="@../css%2520files/courses.css"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.javaproject.CoursesController">

    <children>
        <VBox spacing="8.0" styleClass="welcome-section">
            <children>
                <Label styleClass="welcome-title" text="My Courses" />
                <Label styleClass="welcome-subtitle" text="Manage your courses and academic schedule" />
            </children>
        </VBox>

        <VBox spacing="20.0" styleClass="courses-main-card" VBox.vgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Label styleClass="card-title" text="📚 Course List" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Label fx:id="courseCountBadge" styleClass="card-badge" text="0 courses" />
                    </children>
                </HBox>

                <VBox spacing="12.0" styleClass="add-course-section">
                    <children>
                        <Label styleClass="section-label" text="Add New Course" />
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <TextField fx:id="courseNameField" onAction="#handleAddCourse" promptText="Course name (e.g., Data Structures)" styleClass="course-input" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="courseCodeField" onAction="#handleAddCourse" prefWidth="150.0" promptText="Code (e.g., CS201)" styleClass="course-input" />
                                <TextField fx:id="courseCreditsField" onAction="#handleAddCourse" prefWidth="100.0" promptText="Credits" styleClass="course-input" />
                                <Button fx:id="addCourseButton" onAction="#handleAddCourse" styleClass="add-course-button" text="+ Add Course" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="section-label" text="Your Courses" />
                        <ListView fx:id="coursesListView" onMouseClicked="#handleCourseClick" styleClass="courses-list" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <Label fx:id="selectionLabel" styleClass="selection-label" text="Select a course to delete" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Button fx:id="deleteSelectedButton" onAction="#handleDeleteSelected" styleClass="delete-course-button" text="🗑 Delete Selected" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
            </padding>
        </VBox>
    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
</VBox>